{
  "name": "XO Telegram Bot",
  "description": "Production-ready Tic-Tac-Toe Telegram bot with PvP, AI, Tournaments, Coins, ELO and multilingual support.",
  "keywords": ["telegram", "bot", "game", "python"],
  "repository": "https://github.com/YOUR_USERNAME/xo-telegram-bot",

  "stack": "heroku-24",

  "buildpacks": [
    { "url": "heroku/python" }
  ],

  "env": {
    "BOT_TOKEN": {
      "description": "Telegram bot token from @BotFather (e.g. 123456:ABCdef...)",
      "required": true
    },
    "BOT_USERNAME": {
      "description": "Bot username WITHOUT @ (e.g. MyXOBot)",
      "required": true
    },
    "MONGO_URI": {
      "description": "MongoDB Atlas URI: mongodb+srv://user:pass@cluster.mongodb.net/xobot",
      "required": true
    },
    "DB_NAME": {
      "description": "MongoDB database name",
      "value": "xobot",
      "required": true
    },
    "UPDATE_CHANNEL": {
      "description": "Your Telegram update channel WITH @ (e.g. @MyBotUpdates)",
      "required": true
    },
    "SUPPORT_USERNAME": {
      "description": "Support Telegram username WITHOUT @ (e.g. MySupport)",
      "required": true
    },
    "OWNER_ID": {
      "description": "Your Telegram user ID — get it from @userinfobot",
      "required": true
    },
    "BOT_THINK_DELAY": {
      "description": "Seconds the bot pauses before making a move (default: 1.2)",
      "value": "1.2",
      "required": false
    },
    "WEBHOOK_URL": {
      "description": "Set AFTER deploy: https://YOUR-APP-NAME.herokuapp.com  — leave blank now, bot uses polling until you set this.",
      "value": "",
      "required": false
    }
  },

  "formation": {
    "worker": {
      "quantity": 1,
      "size": "standard-2x"
    }
  },

  "addons": []
}
